# Copy this file to .env and fill in all required values.
#   cp example.env .env
#
# .env is git-ignored. Never commit real secret values.

# ── Domain ────────────────────────────────────────────────────────────────────
NGINX_SERVER_NAME=cs-mooc.tou.edu.kz

# ── Next.js public URLs (baked into the frontend build) ───────────────────────
NEXT_PUBLIC_SITE_URL=https://cs-mooc.tou.edu.kz/
NEXT_PUBLIC_API_URL=https://cs-mooc.tou.edu.kz/api/v1/
NEXT_PUBLIC_MEDIA_URL=https://cs-mooc.tou.edu.kz/
INTERNAL_API_URL=http://api:8000/api/v1/

# ── Next.js ───────────────────────────────────────────────────────────────────
# Required for multi-server deployments or consistent server action keys across builds
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode('utf-8'))"
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ── Platform ──────────────────────────────────────────────────────────────────
PLATFORM_DOMAIN=cs-mooc.tou.edu.kz
PLATFORM_SSL=true
PLATFORM_COOKIE_SECURE=true
PLATFORM_PORT=8000
PLATFORM_ALLOWED_ORIGINS=https://cs-mooc.tou.edu.kz
PLATFORM_ALLOWED_REGEXP=^https?://cs-mooc\.tou\.edu\.kz(:\d+)?$
PLATFORM_CONTACT_EMAIL=contact@example.com
PLATFORM_DEVELOPMENT_MODE=false
PLATFORM_LOGFIRE_ENABLED=false
PLATFORM_TIMEZONE="Asia/Almaty"

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=openu
POSTGRES_DB=openu
POSTGRES_PASSWORD=                    # required — generate: openssl rand -hex 32
PLATFORM_SQL_CONNECTION_STRING=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────────────────────────
PLATFORM_REDIS_CONNECTION_STRING=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# HS256 JWT Secret. Generate once with:
#   python -c "import secrets; print(secrets.token_hex(64))"
PLATFORM_JWT_SECRET=    # required — see generation command above

# ── Google OAuth ──────────────────────────────────────────────────────────────
PLATFORM_GOOGLE_CLIENT_ID=
PLATFORM_GOOGLE_CLIENT_SECRET=
PLATFORM_GOOGLE_REDIRECT_URI=https://cs-mooc.tou.edu.kz/api/v1/auth/google/callback

# ── AI ────────────────────────────────────────────────────────────────────────
PLATFORM_OPENAI_API_KEY=
PLATFORM_AI_MODERATION_ENABLED=true
PLATFORM_AI_MODERATION_MODEL=omni-moderation-latest

# ── Email ─────────────────────────────────────────────────────────────────────
PLATFORM_RESEND_API_KEY=
PLATFORM_SYSTEM_EMAIL_ADDRESS=


# ── Code runner (only needed with --profile code-runner) ─────────────────────
JUDGE0_URL=http://judge0-server:2358

# ── Bootstrap — remove after first deploy ────────────────────────────────────
# PLATFORM_INITIAL_ADMIN_EMAIL=
# PLATFORM_INITIAL_ADMIN_PASSWORD=
