# Local backend example only.
# Runtime containers read environment variables from the process environment, typically via extra/.env.
# This file is not auto-loaded by the backend at runtime.

PLATFORM_CONTACT_EMAIL=contact@cs-mooc.tou.edu.kz

# general
PLATFORM_DEVELOPMENT_MODE=true

# security — HS256 secret key.
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
PLATFORM_JWT_SECRET="<64-byte-hex-string>"

# Google OAuth
# Required when Google sign-in is enabled, string
PLATFORM_GOOGLE_CLIENT_ID="your-google-client-id"
# Required when Google sign-in is enabled, secret string
PLATFORM_GOOGLE_CLIENT_SECRET="your-google-client-secret"
PLATFORM_GOOGLE_REDIRECT_URI="http://localhost:1338/api/v1/auth/google/callback"

# hosting config
PLATFORM_DOMAIN=cs-mooc.tou.edu.kz
PLATFORM_SSL=true
PLATFORM_COOKIE_SECURE=false
PLATFORM_PORT=1338
PLATFORM_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
PLATFORM_COOKIE_DOMAIN=.localhost
PLATFORM_ALLOWED_REGEXP=\b((?:https?://)[^\s/$.?#].[^\s]*)\b
PLATFORM_SQL_CONNECTION_STRING=postgresql+psycopg://openu:openu@localhost:5432/openu
PLATFORM_REDIS_CONNECTION_STRING=redis://localhost:6379/0

# AI (all optional — these are the defaults, override as needed)
PLATFORM_OPENAI_API_KEY="secret"
PLATFORM_OPENROUTER_API_KEY="secret"
PLATFORM_AI_MODERATION_ENABLED=true
PLATFORM_AI_MODERATION_MODEL=omni-moderation-latest

# Judge0 - code execution service
JUDGE0_URL=http://localhost:2358

# Mailing config
PLATFORM_RESEND_API_KEY="secret"
PLATFORM_SYSTEM_EMAIL_ADDRESS="contact@cs-mooc.tou.edu.kz"

PLATFORM_LOGFIRE_ENABLED=false

# One-time bootstrap only. Do not keep these in a shared runtime env file.
# PLATFORM_INITIAL_ADMIN_EMAIL="meirbek.dev@gmail.com"
# PLATFORM_INITIAL_ADMIN_PASSWORD="123qweasdzxc"
