    "lint:empty-folders": "node scripts/check-empty-folders.mjs",
    "lint:fix": "eslint --fix . --cache",
    "oxlint": "oxlint --type-aware --type-check --fix --fix-suggestions --fix-dangerously",
    "format": "oxfmt --write",
    "start": "next start",
    "check-types": "next typegen && tsgo --noEmit",
    "bundle:analyze": "next experimental-analyze",
