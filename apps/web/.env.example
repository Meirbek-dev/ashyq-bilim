# Local web example only.
# For Docker deployments, copy extra/example-conf.env to extra/.env and keep the shared app env there.

# Backend URLs
NEXT_PUBLIC_API_URL=http://localhost:1338/api/v1/
NEXT_PUBLIC_SITE_URL=http://localhost:3000/
# Optional when media files are served from a separate origin.
NEXT_PUBLIC_MEDIA_URL=http://localhost:1338/

INTERNAL_API_URL=http://localhost:1338/api/v1/

# NextAuth
NEXTAUTH_SECRET="changeme"
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID="client-id-here"
GOOGLE_CLIENT_SECRET="client-secret-here"

# Optional cookie override for non-standard deployments.
# COOKIE_DOMAIN=example.com

NEXT_TELEMETRY_DISABLED=1
