# Nginx configuration template.
# Docker will run envsubst on this file before Nginx reads it.
# Variables expanded at runtime:
#   NGINX_SERVER_NAME  — the public hostname, e.g. cs-mooc.tou.edu.kz
#                        set via docker-compose.yml environment or the .env file
#
# Nginx variables ($host, $remote_addr, etc.) are NOT expanded because
# they are not present in the container environment.

# ---------------------------------------------------------------------------
# Proxy cache zone — declared at http-context level (conf.d files are
# included inside the http block by default).
# ---------------------------------------------------------------------------
proxy_cache_path /var/cache/nginx/app
  levels=1:2
  keys_zone=app_cache:10m
  max_size=1g
  inactive=60m
  use_temp_path=off;

# ---------------------------------------------------------------------------
# Rate-limit zones
# ---------------------------------------------------------------------------
# Auth and mutation endpoints: 10 req/s per IP, burst of 20
limit_req_zone $binary_remote_addr zone=auth_limit:10m rate=10r/s;
# General API: 30 req/s per IP, burst of 60
limit_req_zone $binary_remote_addr zone=api_limit:10m  rate=30r/s;
# Global/Frontend: 2000 req/s per IP, burst of 2500 (Next.js chunk burst support)
limit_req_zone $binary_remote_addr zone=global_limit:10m rate=2000r/s;

# ---------------------------------------------------------------------------
# Upstream timeouts (applied once here, referenced per-location)
# ---------------------------------------------------------------------------
proxy_connect_timeout 10s;
proxy_send_timeout    60s;
proxy_read_timeout    60s;

# ---------------------------------------------------------------------------
# Real-IP — restore original client IP from upstream reverse proxy
# The edge proxy at 192.168.1.x forwards X-Forwarded-For with the real client IP.
# ---------------------------------------------------------------------------
real_ip_header    X-Forwarded-For;
set_real_ip_from  192.168.0.0/16;
set_real_ip_from  10.0.0.0/8;
set_real_ip_from  172.16.0.0/12;
real_ip_recursive on;

# ---------------------------------------------------------------------------
# Gzip compression
# ---------------------------------------------------------------------------
gzip            on;
gzip_vary       on;
gzip_proxied    any;
gzip_comp_level 5;
gzip_min_length 1024;
gzip_types
  text/plain
  text/css
  text/javascript
  application/javascript
  application/json
  application/xml
  image/svg+xml
  font/woff2;

# ---------------------------------------------------------------------------
# Shared proxy header macro — included in every location block
# ---------------------------------------------------------------------------
# (Nginx does not support real macros in conf.d; we use a common include
#  approach by setting these explicitly in each block below.)

# ---------------------------------------------------------------------------
# Detect whether this request was originally HTTPS (set by a TLS-terminating
# upstream reverse proxy, e.g. the edge nginx at 192.168.1.46).
# When $is_forwarded_https = 0, redirect to HTTPS.
# When $is_forwarded_https = 1, proxy directly (TLS already terminated).
# ---------------------------------------------------------------------------
map $http_x_forwarded_proto $is_forwarded_https {
  "https"  1;
  default  0;
}

# ===========================================================================
# HTTP — redirect to HTTPS for direct browser connections;
#         proxy directly when behind a TLS-terminating upstream proxy.
# ===========================================================================
server {
  listen 80;
  server_name ${NGINX_SERVER_NAME};

  # Let's Encrypt / ACME http-01 challenge — always served, no redirect
  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  # Auth endpoints
  location /api/auth {
    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Backend API auth
  location /api/v1/auth {
    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://api:8000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Backend API (general)
  location /api/v1 {
    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://api:8000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Backend static content
  location /content {
    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://api:8000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Next.js static files
  location /_next/static {
    access_log off;

    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Next.js image optimizer
  location /_next/image {
    limit_req zone=global_limit burst=2500 nodelay;
    limit_req_status 429;

    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
  }

  # ISR revalidation / health
  location /api/revalidate {
    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
  }

  location /api/health {
    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
    access_log off;
  }

  # Frontend catch-all
  location / {
    limit_req zone=global_limit burst=2500 nodelay;
    limit_req_status 429;

    if ($is_forwarded_https = 0) { return 301 https://$host$request_uri; }
    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Request-ID      $request_id;
  }
}

# ===========================================================================
# HTTPS
# ===========================================================================
server {
  listen 443 ssl;
  http2  on;
  server_name ${NGINX_SERVER_NAME};

  # -------------------------------------------------------------------------
  # TLS
  # -------------------------------------------------------------------------
  ssl_certificate     /etc/nginx/certs/cert.pem;
  ssl_certificate_key /etc/nginx/certs/key.pem;

  ssl_protocols             TLSv1.2 TLSv1.3;
  ssl_ciphers               ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256;
  ssl_prefer_server_ciphers off;
  ssl_session_cache         shared:SSL:10m;
  ssl_session_timeout       1d;
  ssl_session_tickets       off;

  # -------------------------------------------------------------------------
  # Security headers
  # -------------------------------------------------------------------------
  # HSTS: tell browsers to enforce HTTPS for 1 year, include subdomains
  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  add_header X-Frame-Options            "SAMEORIGIN"                          always;
  add_header X-Content-Type-Options     "nosniff"                             always;
  add_header Referrer-Policy            "strict-origin-when-cross-origin"     always;

  # -------------------------------------------------------------------------
  # Request limits
  # -------------------------------------------------------------------------
  client_max_body_size       500M;
  large_client_header_buffers 4 32k;
  client_body_buffer_size    32k;
  client_header_buffer_size  32k;

  # -------------------------------------------------------------------------
  # Proxy buffers
  # -------------------------------------------------------------------------
  proxy_buffer_size      128k;
  proxy_buffers          4 256k;
  proxy_busy_buffers_size 256k;

  # -------------------------------------------------------------------------
  # Log format — include request ID and upstream timing
  # -------------------------------------------------------------------------
  access_log /var/log/nginx/access.log combined;

  # =========================================================================
  # Location blocks
  # =========================================================================

  # Auth endpoints — strict rate limit (login, register, token refresh, OAuth)
  location /api/auth {
    limit_req zone=auth_limit burst=20 nodelay;
    limit_req_status 429;

    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
  }

  location /api/v1/auth {
    limit_req zone=auth_limit burst=20 nodelay;
    limit_req_status 429;

    proxy_pass http://api:8000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Python Backend API (general)
  location /api/v1 {
    limit_req zone=api_limit burst=60 nodelay;
    limit_req_status 429;

    proxy_pass http://api:8000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Backend static content (user uploads, media)
  location /content {
    proxy_pass http://api:8000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Next.js static files (_next/static) — content-addressed, cache permanently
  location /_next/static {
    access_log off;

    proxy_pass http://web:3000;
    proxy_cache       app_cache;
    proxy_cache_valid 200 365d;
    proxy_cache_bypass $http_cache_control;
    add_header Cache-Control "public, max-age=31536000, immutable";
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Next.js image optimization — transformation endpoint, not immutable
  location /_next/image {
    limit_req zone=global_limit burst=2500 nodelay;
    limit_req_status 429;

    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
  }

  # NextJS revalidation (ISR)
  location /api/revalidate {
    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
  }

  # Next.js health check (must not redirect — used by Docker health check)
  location /api/health {
    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
    access_log off;
  }

  # Frontend catch-all
  location / {
    limit_req zone=global_limit burst=2500 nodelay;
    limit_req_status 429;

    proxy_pass http://web:3000;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Request-ID      $request_id;
  }
}
