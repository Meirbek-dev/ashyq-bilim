# Ashyq Bilim deployment environment template.
# Copy this file to extra/.env for Docker deployments.
# Comments call out type, whether the variable is required, and how it is used.

# Public-facing web URLs
# Required, url
NEXT_PUBLIC_SITE_URL=https://example.com/
# Required, url
NEXT_PUBLIC_API_URL=https://example.com/api/v1/
# Optional, url
# NEXT_PUBLIC_MEDIA_URL=https://media.example.com/

# Internal server-to-server URL used by the Next.js container
# Required in Docker deployments, url
INTERNAL_API_URL=http://localhost:9000/api/v1/

# NextAuth
# Required, secret string
NEXTAUTH_SECRET="generate-a-long-random-secret"
# Required, url
NEXTAUTH_URL=https://example.com

# Google OAuth
# Required when Google sign-in is enabled, string
GOOGLE_CLIENT_ID="your-google-client-id"
# Required when Google sign-in is enabled, secret string
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Frontend runtime flags
NEXT_TELEMETRY_DISABLED=1

# Backend contact and runtime mode
# Required, email
PLATFORM_CONTACT_EMAIL=contact@example.com
# Required in production, bool. Controls backend development-only behavior.
PLATFORM_DEVELOPMENT_MODE=false
# Optional, bool
PLATFORM_LOGFIRE_ENABLED=false
# Optional, timezone name
PLATFORM_TIMEZONE=UTC

# Backend security
# Required, strong secret string
PLATFORM_AUTH_JWT_SECRET_KEY="generate-a-long-random-secret"

# Hosting config
# Required, hostname
PLATFORM_DOMAIN=example.com
# Required, bool
PLATFORM_SSL=true
# Required, int
PLATFORM_PORT=9000
# Required, comma-separated origins
PLATFORM_ALLOWED_ORIGINS=https://example.com
# Optional, cookie domain. Leave unset for localhost/IP deployments.
# PLATFORM_COOKIE_DOMAIN=example.com
# Required, regex string
PLATFORM_ALLOWED_REGEXP=^https?://example\.com(:\d+)?$

# Database and cache
# Required, postgres DSN
PLATFORM_SQL_CONNECTION_STRING=postgresql+psycopg://openu:openu@db:5432/openu
# Required, redis DSN
PLATFORM_REDIS_CONNECTION_STRING=redis://redis:6379/openu

# RBAC cache controls
# Optional, bool
PLATFORM_RBAC_AUDIT_LOGGING_ENABLED=true
# Optional, bool
PLATFORM_RBAC_CACHE_ENABLED=true
# Optional, int seconds
PLATFORM_RBAC_CACHE_TTL_SECONDS=300

# AI services
# Optional, secret string
PLATFORM_OPENAI_API_KEY="your-openai-api-key"
# Optional, bool
PLATFORM_CHROMADB_SEPARATE=true
# Optional, hostname
PLATFORM_CHROMADB_HOST=chromadb
# Optional, int
PLATFORM_CHROMADB_PORT=8000
# Optional, filesystem path for persistent local ChromaDB mode
PLATFORM_CHROMADB_PERSIST_PATH=./chromadb_data

# Judge0 code runner
# Required when coding activities are enabled, url
JUDGE0_URL=http://judge0_server:2358

# Mailing
# Optional, secret string
PLATFORM_RESEND_API_KEY="your-resend-api-key"
# Optional, email
PLATFORM_SYSTEM_EMAIL_ADDRESS="contact@example.com"

# Stripe
# Optional, secret string
PLATFORM_STRIPE_SECRET_KEY=""
# Optional, publishable string
PLATFORM_STRIPE_PUBLISHABLE_KEY=""
# Optional, secret string
PLATFORM_STRIPE_WEBHOOK_STANDARD_SECRET=""
# Optional, secret string
PLATFORM_STRIPE_WEBHOOK_CONNECT_SECRET=""
# Optional, string
PLATFORM_STRIPE_CLIENT_ID=""

# Internal backend-only auth
# Required for internal cloud routes, secret string
CLOUD_INTERNAL_KEY="generate-a-separate-internal-secret"

# One-time bootstrap only. Do not keep these in a shared runtime env file.
# Optional, email
# PLATFORM_INITIAL_ADMIN_EMAIL="admin@example.com"
# Optional, secret string
# PLATFORM_INITIAL_ADMIN_PASSWORD="generate-a-unique-bootstrap-password"

# Test-only switch read directly by the backend test harness.
# TESTING=true
