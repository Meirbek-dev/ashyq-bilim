{
  "name": "ashyq-bilim",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "bun run services && turbo run dev",
    "dev:web": "cd apps/web && bun run dev",
    "dev:api": "cd apps/api && uv run app.py",
    "services": "docker compose up -d db chromadb redis",
    "services:judge0": "docker compose up -d db chromadb redis judge0_workers judge0_server",
    "format": "prettier --write \"**/*.{js,ts,tsx,md,css,json}\"",
    "lint": "turbo run lint",
    "oxlint": "oxlint --type-aware --fix --fix-suggestions --fix-dangerously",
    "start": "turbo run start",
    "check-types": "turbo run check-types",
    "check:permissions": "uv run --project apps/api python scripts/validate-permissions-yaml.py"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-imports": "^1.8.11",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.20"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "bun": ">=1.3.8"
  }
}
